#!/usr/bin/env ruby
# frozen_string_literal: true

# Development / test container entrypoint.
#
# Prepares the environment (gems + database) and then execs the given command,
# defaulting to the Rails server. Runs on `docker compose up` (development) and
# `docker compose run --rm tests` (CI).

require 'fileutils'

APP_ROOT = File.expand_path('..', __dir__)
Dir.chdir(APP_ROOT)

# Default to booting the Rails server when no command is given:
ARGV.concat(%w[rails server -b 0.0.0.0]) if ARGV.empty?

def run(command)
  system(command) || abort("\n== Command failed, exiting: #{command} ==")
end

# Ensure the project gems are installed:
run 'bundle check > /dev/null 2>&1 || bundle install'

command = ARGV.first

if %w[rails rake rspec puma].include?(command)
  # Prepare the database (create + load schema, idempotent). db:prepare — not
  # db:test:prepare — because the SQL schema format (FTS5) trips the latter's
  # environment check. Specs run against the test database.
  if command == 'rspec'
    run 'RAILS_ENV=test bundle exec rails db:prepare'
  else
    run 'bundle exec rails db:prepare'
  end

  # Remove a possibly pre-existing server.pid before booting the server:
  if command == 'rails' && ARGV[1].to_s.start_with?('s')
    FileUtils.rm_f(File.join(APP_ROOT, 'tmp', 'pids', 'server.pid'))
  end
end

exec(*ARGV)
