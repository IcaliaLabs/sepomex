.git/
.gitignore

# Never bake the credentials master key into the image — production reads
# SECRET_KEY_BASE (or RAILS_MASTER_KEY) from the environment.
config/master.key

Dockerfile
docker-compose.yml
*.env
dev-entrypoint.sh
.dockerignore

log/*.log

tmp/*
!tmp/pids/
!tmp/pids
!tmp/pids/.keep

.rspec
spec/

# Ignore history files
**/.*_hist*

# Ignore database dumps
db/dumps/*
!db/dumps/.keep

# Never ship local dev/test databases (33MB+) — the release stage builds
# db/production.sqlite3 from scratch via db:create + db:migrate + data:load.
db/*.sqlite3
db/*.sqlite3-*

# SimpleCov output.
coverage/

# Fly.io deploy config — not part of the app image.
fly.toml
.fly/
